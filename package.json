{
  "name": "@rowvyn/servicetitan-cli",
  "version": "0.1.4",
  "description": "ServiceTitan CLI",
  "author": "Montrell Cruse <montrell@rowvyn.com>",
  "license": "MIT",
  "keywords": [
    "servicetitan",
    "cli",
    "api",
    "hvac",
    "field-service",
    "rowvyn"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/montrellcruse/servicetitan-cli"
  },
  "homepage": "https://github.com/montrellcruse/servicetitan-cli#readme",
  "bugs": {
    "url": "https://github.com/montrellcruse/servicetitan-cli/issues"
  },
  "type": "module",
  "bin": {
    "st": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "exports": "./dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@oclif/core": "^3.0.0",
    "@oclif/plugin-help": "^6.0.0",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "csv-stringify": "^6.5.2",
    "keytar": "^7.9.0",
    "ora": "^8.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "oclif": {
    "bin": "st",
    "dirname": "st",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Authenticate with ServiceTitan and manage credential profiles"
      },
      "customers": {
        "description": "Search, view, create, and update customer records"
      },
      "jobs": {
        "description": "Book, search, update, cancel, and complete service jobs"
      },
      "invoices": {
        "description": "View and search invoice records"
      },
      "techs": {
        "description": "View technician profiles and performance data"
      },
      "memberships": {
        "description": "Manage membership plans and customer memberships"
      },
      "estimates": {
        "description": "View and search estimate records"
      },
      "leads": {
        "description": "Manage incoming leads, dismiss them, or convert them to booked jobs"
      },
      "pricebook": {
        "description": "Browse services, materials, and equipment from the pricebook"
      },
      "dispatch": {
        "description": "View the dispatch board, capacity, and assign technicians"
      },
      "reporting": {
        "description": "List and run ServiceTitan reports"
      },
      "bookings": {
        "description": "Accept or dismiss online booking requests"
      },
      "api": {
        "description": "Direct API access - call any ServiceTitan endpoint"
      },
      "completion": {
        "description": "Install shell tab completion for bash, zsh, or fish"
      }
    }
  }
}
